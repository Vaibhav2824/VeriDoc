# Copy to .env and fill in your values. Never commit .env.

# ── M0: VLM API keys (set at least one; GROQ_API_KEY takes priority) ──────────
# Groq free tier: 500K tokens/day for llama-4-scout — in practice this is
# ~28-29 of the 100 benchmark docs per run (each needs 2 calls: extractor +
# verifier), not the request-count headline suggests. The cap is a rolling
# 24h window, not a calendar-day reset — see eval/REPORT.md's "Known
# limitation" note. eval.run caches successful extractions locally
# (eval/.cache/) so repeated runs accumulate coverage instead of restarting.
# Get key: console.groq.com
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Gemini fallback (used when GROQ_API_KEY is not set)
GEMINI_API_KEY=your_gemini_key_here
# gemini-2.0-flash-lite has higher free RPD than gemini-2.5-flash (20 req/day)
GEMINI_MODEL=gemini-2.0-flash-lite

# ── M1: Langfuse tracing ──────────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── M3: Neon Postgres + pgvector (few-shot exemplar retrieval) ────────────────
# Create a free project at neon.tech, then run services.api.rag.store.init_schema()
# once to enable the pgvector extension and create the exemplars table.
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# ── M3: Ollama (on-prem adapter — not the hot path) ──────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:3b

# ── Eval / CI ─────────────────────────────────────────────────────────────────
# Confidence threshold: fields below this are abstained (not auto-accepted)
CONFIDENCE_THRESHOLD=0.80
# Max retries per extraction node before failing closed
MAX_RETRIES=3
# Seconds to sleep between eval requests (respect free-tier RPM limits)
EVAL_RATE_LIMIT_SLEEP=4
