# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Environments
.env
.venv/
venv/

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Local extraction cache (fingerprinted; rebuilds cleanly from eval/labels/ + eval/docs/)
eval/.cache/

# Logs & temp
*.log
*.tmp

# OS
.DS_Store
Thumbs.db

# Frontend (deferred)
web/node_modules/
web/.next/
web/out/

# Notebooks
.ipynb_checkpoints/

# Eval docs (don't commit raw PDFs to git; store separately or use Git LFS)
eval/docs/*.pdf
eval/docs/*.png
eval/docs/*.jpg
eval/docs/*.jpeg

# Raw Kaggle batch downloads (same policy as eval/docs — keep the CSV ground
# truth, exclude the raw PDFs; scripts/import_batch_labels.py regenerates docs)
samples/**/*.pdf
samples/**/*.png
samples/**/*.jpg
samples/**/*.jpeg

# Claude Code internal state
.claude/

# Graphify generated artifacts
graphify-out/

# Secrets / local overrides
*.local
